{
  "name": "dreamscape-tests",
  "version": "1.0.0",
  "description": "Comprehensive test suite for Dreamscape microservices architecture",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:working && npm run test:e2e",
    "test:working": "jest --testPathPattern=\"(simple-test|mock-service).test.js\" --forceExit",
    "test:unit": "jest --testPathPattern=unit-tests",
    "test:integration": "npm run test:integration:auth && npm run test:integration:user && npm run test:integration:kafka",
    "test:integration:kafka": "jest --config=./integration/kafka/jest.config.kafka.js",
    "test:integration:auth": "jest --config=./tools/setup/jest.config.integration.js --testPathPattern=\"integration/api/auth\"",
    "test:integration:user": "jest --config=./tools/setup/jest.config.integration.js --testPathPattern=\"integration/api/user\"",
    "test:e2e": "npm run test:e2e:voyage && npm run test:e2e:web && npm run test:e2e:cart",
    "test:e2e:voyage": "cypress run --config-file tools/setup/cypress.config.js",
    "test:e2e:web": "cypress run --config-file tools/setup/web-client-cypress.config.ts",
    "test:e2e:cart": "cypress run --spec tests/e2e/web-client/cart-booking-flow.cy.js",
    "test:e2e:cart:open": "cypress open --spec tests/e2e/web-client/cart-booking-flow.cy.js",
    "test:e2e:cart:kafka": "cypress run --spec tests/e2e/web-client/cart-booking-kafka.cy.js",
    "test:e2e:cart:kafka:open": "cypress open --spec tests/e2e/web-client/cart-booking-kafka.cy.js",
    "test:health": "jest --config=jest.config.health.js",
    "test:health:unit": "jest --config=jest.config.health.js --testPathPattern=unit/health",
    "test:health:integration": "jest --config=jest.config.health.js --testPathPattern=integration/health",
    "test:health:coverage": "jest --config=jest.config.health.js --coverage",
    "test:health:watch": "jest --config=jest.config.health.js --watch",
    "test:health:realdb": "jest --config=jest.config.realdb.js",
    "test:health:realdb:auth": "jest --config=jest.config.realdb.js --testPathPattern=auth-health",
    "test:health:realdb:verbose": "jest --config=jest.config.realdb.js --verbose",
    "test:dr538": "jest --config=jest.config.auth-unit.js --verbose",
    "test:dr538:coverage": "jest --config=jest.config.auth-unit.js --coverage",
    "test:test002": "jest --config=jest.config.test002.js --verbose",
    "test:test002:coverage": "jest --config=jest.config.test002.js --coverage",
    "test:test003": "jest --config=jest.config.test003.js --verbose",
    "test:test003:coverage": "jest --config=jest.config.test003.js --coverage",
    "test:test004": "jest --config=jest.config.test004.js --verbose",
    "test:test004:coverage": "jest --config=jest.config.test004.js --coverage",
    "test:test022": "jest --config=jest.config.test022.js --verbose",
    "test:test022:coverage": "jest --config=jest.config.test022.js --coverage",
    "test:test023": "jest --config=jest.config.test023.js --verbose",
    "test:test023:coverage": "jest --config=jest.config.test023.js --coverage",
    "test:test024": "jest --config=jest.config.test024.js --verbose",
    "test:test024:coverage": "jest --config=jest.config.test024.js --coverage",
    "test:performance": "npm run test:performance:api && npm run test:performance:frontend",
    "test:performance:api": "echo 'API performance tests - to be implemented'",
    "test:performance:frontend": "echo 'Frontend performance tests - to be implemented'",
    "test:security": "npm run test:security:static && npm run test:security:penetration",
    "test:security:static": "echo 'Static security analysis - to be implemented'",
    "test:security:penetration": "echo 'Penetration tests - to be implemented'",
    "test:accessibility": "echo 'Accessibility tests - to be implemented'",
    "test:coverage": "jest --config=jest.config.js",
    "test:coverage:working": "jest --config=jest.config.js --testPathPattern=\"(simple-test|mock-service).test.js\" --coverageDirectory=coverage/working",
    "test:coverage:all-services": "npm run test:coverage:ai && npm run test:coverage:auth && npm run test:coverage:user && npm run test:coverage:payment && npm run test:coverage:voyage && npm run test:coverage:web && npm run test:coverage:panorama",
    "test:coverage:ai": "jest --config=jest.config.js --testPathPattern=\"(DR-76|US-IA)\" --coverageDirectory=coverage/ai",
    "test:coverage:auth": "jest --config=jest.config.js --testPathPattern=\"auth-middleware\" --coverageDirectory=coverage/auth",
    "test:coverage:user": "jest --config=jest.config.js --testPathPattern=\"(user-service|profile-routes|simple-unit)\" --coverageDirectory=coverage/user",
    "test:coverage:payment": "jest --config=jest.config.js --testPathPattern=\"payment-service\" --coverageDirectory=coverage/payment --passWithNoTests",
    "test:coverage:voyage": "jest --config=jest.config.js --testPathPattern=\"(DR-61.*unit|DR-67.*unit|DR-69.*unit)\" --coverageDirectory=coverage/voyage",
    "test:coverage:web": "jest --config=jest.config.js --testPathPattern=\"web-client\" --coverageDirectory=coverage/web-client --passWithNoTests",
    "test:coverage:panorama": "jest --config=jest.config.js --testPathPattern=\"panorama-service\" --coverageDirectory=coverage/panorama --passWithNoTests",
    "test:dr59": "bash scripts/test-profile-dr59.sh",
    "test:dr59:simple": "bash scripts/test-profile-dr59.sh simple",
    "test:dr59:unit": "bash scripts/test-profile-dr59.sh unit",
    "test:dr59:integration": "bash scripts/test-profile-dr59.sh integration",
    "test:dr59:coverage": "bash scripts/test-profile-dr59.sh coverage",
    "test:profile": "jest tests/DR-59-profile-user/ --verbose",
    "test:profile:simple": "jest tests/DR-59-profile-user/unit/simple-unit.test.ts tests/DR-59-profile-user/integration/simple-integration.test.ts --verbose",
    "test:dr69": "jest tests/DR-69-amadeus-activities/ --verbose",
    "test:dr69:unit": "jest tests/DR-69-amadeus-activities/unit/ --verbose",
    "test:dr69:integration": "jest tests/DR-69-amadeus-activities/integration/ --verbose",
    "test:dr69:e2e": "jest tests/DR-69-amadeus-activities/e2e/ --verbose",
    "test:dr69:coverage": "jest tests/DR-69-amadeus-activities/ --coverage --verbose",
    "test:integration:gdpr": "jest --config=./tools/setup/jest.config.integration.js --testPathPattern=\"integration/api/user/gdpr\"",
    "test:integration:kafka:gdpr": "jest --config=./integration/kafka/jest.config.kafka.js --testPathPattern=\"gdpr-events\"",
    "test:e2e:gdpr": "cypress run --spec tests/e2e/web-client/gdpr-compliance.cy.js",
    "test:e2e:gdpr:open": "cypress open --spec tests/e2e/web-client/gdpr-compliance.cy.js",
    "test:ia009": "jest tests/US-IA-009-ml-diversity/ --verbose",
    "test:ia009:unit": "jest tests/US-IA-009-ml-diversity/unit/ --verbose",
    "test:ia009:integration": "jest tests/US-IA-009-ml-diversity/integration/ --verbose",
    "test:ia010": "jest tests/US-IA-010-frontend-integration/ --verbose",
    "test:ia010:e2e": "cypress run --spec tests/e2e/web-client/recommendation-flow.cy.js",
    "test:ia010:e2e:open": "cypress open --spec tests/e2e/web-client/recommendation-flow.cy.js",
    "test:e2e:auth": "cypress run --spec tests/e2e/web-client/authentication.cy.js",
    "test:e2e:auth:open": "cypress open --spec tests/e2e/web-client/authentication.cy.js",
    "test:e2e:bookings": "cypress run --spec tests/e2e/web-client/booking-management.cy.js",
    "test:e2e:bookings:open": "cypress open --spec tests/e2e/web-client/booking-management.cy.js",
    "test:e2e:vr": "cypress run --spec tests/e2e/web-client/vr-access.cy.js",
    "test:e2e:vr:open": "cypress open --spec tests/e2e/web-client/vr-access.cy.js",
    "test:e2e:ai": "cypress run --spec tests/e2e/web-client/ai-recommendations.cy.js",
    "test:e2e:ai:open": "cypress open --spec tests/e2e/web-client/ai-recommendations.cy.js",
    "test:e2e:mvp": "cypress run --spec 'tests/e2e/web-client/{authentication,booking-management,cart-booking-flow,vr-access,ai-recommendations,gdpr-compliance}.cy.js'",
    "test:e2e:mvp:open": "cypress open --spec 'tests/e2e/web-client/{authentication,booking-management,cart-booking-flow,vr-access,ai-recommendations,gdpr-compliance}.cy.js'",
    "test:dr575": "jest --config=tests/DR-575-vr-fallback/jest.config.js --verbose",
    "test:dr575:unit": "jest --config=tests/DR-575-vr-fallback/jest.config.js --testPathPattern=unit --verbose",
    "test:dr567": "jest --config=jest.config.dr567.js --forceExit --verbose",
    "test:dr567:coverage": "jest --config=jest.config.dr567.js --forceExit --coverage",
    "test:dr568": "jest --config=jest.config.dr568.js --forceExit --verbose",
    "test:dr568:coverage": "jest --config=jest.config.dr568.js --forceExit --coverage",
    "test:all": "npm run test && npm run test:performance && npm run test:security && npm run test:accessibility",
    "setup": "node tools/setup/environment.js",
    "mock:start": "node mocks/services/mock-server.js",
    "report": "node tools/reporting/generate-report.js",
    "report:coverage": "node tools/reporting/coverage-report.js",
    "coverage-and-report": "npm run test:coverage && npm run report:coverage",
    "ci": "npm run setup && npm run test:all && npm run report"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "@types/node": "^20.8.0",
    "cypress": "^13.3.0",
    "jest": "^29.7.0",
    "kafkajs": "^2.2.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.28.5",
    "@dreamscape/db": "file:../dreamscape-services/db",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.55.0",
    "@prisma/client": "^7.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^6.0.3",
    "axios": "^1.5.0",
    "babel-jest": "^30.1.2",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jest-environment-jsdom": "^30.2.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "keywords": [
    "testing",
    "microservices",
    "dreamscape",
    "integration",
    "e2e",
    "performance",
    "security"
  ],
  "author": "Dreamscape Team",
  "license": "MIT"
}
