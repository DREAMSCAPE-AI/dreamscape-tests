{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "target": "ES2020",
    "module": "commonjs",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@dreamscape/db": ["../dreamscape-services/db/src/index.ts"],
      "@/*": ["../dreamscape-services/voyage/src/*"],
      "@ai/*": ["../dreamscape-services/ai/src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "cypress",
    "**/*.cy.ts",
    "**/*.cy.js",
    "**/cypress/**"
  ]
}
