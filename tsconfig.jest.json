{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "target": "ES2020",
    "module": "commonjs",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "cypress",
    "**/*.cy.ts",
    "**/*.cy.js",
    "**/cypress/**"
  ]
}
